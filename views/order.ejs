<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>My Orders</title>
    <link rel="stylesheet" href="/css/orders.css">
    <style>
        .order-actions{
    margin-top:20px;
}

.cancel-btn{
    background:#ef4444;
    color:white;
    border:none;
    padding:10px 18px;
    border-radius:8px;
    cursor:pointer;
    font-weight:bold;
}

.cancel-btn:hover{
    background:#dc2626;
}
    </style>
</head>
<body>

    <%- include('./partials/nav.ejs') %>

    <div class="orders-container">

        <h1>My Orders</h1>

        <% if(orders.length === 0){ %>

            <div class="empty-orders">

                <h2>No Orders Found</h2>

                <p>
                    Start shopping to place your first order.
                </p>

                <a href="/products" class="shop-btn">
                    find Products
                </a>

            </div>

        <% } else { %>

            <% orders.forEach(order => { %>

                <div class="order-card">

                    <div class="order-header">

                        <div>
                            <h3>Order ID</h3>
                            <p><%= order._id %></p>
                        </div>

                        <div>
                            <h3>Date</h3>
                            <p>
                                <%= order.createdAt.toDateString() %>
                            </p>
                        </div>

                        <div>
                            <h3>Status</h3>
                            <span class="status">
                                <%= order.status %>
                            </span>
                        </div>

                    </div>

                    <div class="items-section">

                        <% order.items.forEach(item => { %>

                            <div class="item-row">

                                <div>
                                    <strong>
                                        <%= item.name %>
                                    </strong>
                                </div>

                                <div>
                                    ₹<%= item.price %>
                                </div>

                                <div>
                                    Qty: <%= item.quantity %>
                                </div>

                            </div>
                           

                        <% }) %>
                        <div class="order-actions">

                            <% if(order.status === "Placed"){ %>
                        
                                <form action="/orders/cancel/<%= order._id %>" method="POST">
                        
                                    <button type="submit" class="cancel-btn">
                                        Cancel Order
                                    </button>
                        
                                </form>
                        
                            <% } %>
                        
                        </div>
                    </div>

                    <div class="total-section">

                        Total Amount :
                        ₹<%= order.totalAmount %>

                    </div>

                </div>

            <% }) %>

        <% } %>

    </div>

</body>
</html>